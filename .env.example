# ============================================================================
# These are the exact "Variables" you paste into Railway (Project -> Variables).
# Do NOT commit a real .env file with real secrets to git.
# ============================================================================

# --- Deriv API -------------------------------------------------------------
# Get these from your Deriv account: Settings -> API Token (https://app.deriv.com/account/api-token)
# The token is generated FOR a specific account (demo or real) — pick the right one on Deriv's
# site depending on ACCOUNT_TYPE below.
DERIV_APP_ID=1089
DERIV_API_TOKEN=your_deriv_api_token_here

# "demo" or "real". This is a safety check: on startup the bot authorizes with your token,
# reads back whether Deriv says that account is virtual (demo) or real, and REFUSES to start
# if it doesn't match what you set here. Prevents a copy-pasted wrong token from silently
# trading real money.
ACCOUNT_TYPE=demo

# Extra deliberate switch. Even with ACCOUNT_TYPE=real and a real-money token, the bot will
# refuse to place trades unless this is explicitly "yes". Leave it "no" until you've actually
# reviewed everything and mean to go live.
CONFIRM_LIVE_TRADING=no

# --- Supabase (reuse your existing project/tables from your other bots) ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_or_anon_key

# --- Risk / staking ----------------------------------------------------------
BASE_STAKE=1.0            # stake used to quote candidates + the minimum trade size, in account currency
MAX_STAKE=5.0             # hard ceiling per trade regardless of what Kelly sizing suggests
EV_FLOOR=0.02             # minimum required EV per unit stake (0.02 = candidate must show +2% edge)
KELLY_FRACTION=0.25       # fractional Kelly multiplier (0.25 = quarter-Kelly, conservative)
MIN_WIN_PROB_FLOOR=0.55   # conservative (CI lower-bound) win probability required to trade a cell
